# ============================================================
# SMART HEALTH RECORD - ENVIRONMENT VARIABLES
# ============================================================
# STEP 1: Copy this file → rename to .env
# STEP 2: Go to https://mongodb.com/cloud/atlas
# STEP 3: Create free account → free M0 cluster
# STEP 4: Click Connect → Drivers → Copy connection string
# STEP 5: Replace <username> and <password> below
# ============================================================

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smarthealth?retryWrites=true&w=majority

PORT=3000
NODE_ENV=development
